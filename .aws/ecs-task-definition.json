{
  "containerDefinitions": [
    {
      "name": "django-watchlist",
      "image": "124969139066.dkr.ecr.us-east-1.amazonaws.com/watchlist/api:v2",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DJANGO_ALLOW_ASGI_HOST",
          "value": "true"
        },
        {
          "name": "CLOUDFRONT_DOMAIN",
          "value": "dlkbs05wn642s.cloudfront.net"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_USER",
          "value": "admino"
        },
        {
          "name": "AWS_S3_REGION_NAME",
          "value": "us-east-1"
        },
        {
          "name": "DB_NAME",
          "value": "watchlist"
        },
        {
          "name": "DEBUG",
          "value": "0"
        },
        {
          "name": "DB_HOST",
          "value": "watchlist-api-default-rds-pg.ctc5n2rchnq5.us-east-1.rds.amazonaws.com"
        },
        {
          "name": "AWS_STORAGE_BUCKET_NAME",
          "value": "watchlist-api-django-api-static-files"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "DB_PASS",
          "valueFrom": "arn:aws:ssm:us-east-1:124969139066:parameter/watchlist-api-default/db_password"
        },
        {
          "name": "DJANGO_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:124969139066:parameter/watchlist-api-default/django_secret_key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/watchlist-api-default",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ],
  "family": "watchlist-api-default-task",
  "taskRoleArn": "arn:aws:iam::124969139066:role/watchlist-api-default-ecsTaskRole",
  "executionRoleArn": "arn:aws:iam::124969139066:role/watchlist-api-default-ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512"
}
